# Copie ce fichier en `.env` et remplace par tes vraies valeurs Firebase.
# Console Firebase → Paramètres du projet → Tes applications → Config
FIREBASE_API_KEY=VOTRE_API_KEY
FIREBASE_AUTH_DOMAIN=VOTRE_PROJET.firebaseapp.com
FIREBASE_PROJECT_ID=VOTRE_PROJET_ID
FIREBASE_STORAGE_BUCKET=VOTRE_PROJET.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=VOTRE_SENDER_ID
FIREBASE_APP_ID=VOTRE_APP_ID
FIREBASE_MEASUREMENT_ID=VOTRE_MEASUREMENT_ID
